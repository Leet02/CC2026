<launch>
  <node pkg="odom_visualization" type="odom_visualization" name="drone_1_odom_visualization" output="screen">
    <remap from="~odom" to="/fastlio_odom" />  <!-- 订阅您的odom话题 -->
    <param name="_frame_id" value="map" />  <!-- 统一frame -->
    <param name="color/r" value="1.0"/>  <!-- 自定义颜色 -->
    <param name="color/g" value="0.0"/>
    <param name="color/b" value="0.0"/>
    <param name="color/a" value="1.0"/>
    <param name="covariance_scale" value="100.0"/>
    <param name="robot_scale" value="1.0"/>
    <param name="tf45" value="false"/>
  </node>
</launch>
